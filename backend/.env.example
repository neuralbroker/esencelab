# Backend Environment Variables
# Copy this file to .env for local development
# Copy to Vercel project settings for production

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=INFO

# Database - Supabase (required for production)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
TRUST_PROXY=1

# AI Service
AI_SERVICE_URL=http://localhost:3002
AI_INTERNAL_AUTH_TOKEN=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REASONING_EFFORT=high
GROQ_SERVICE_TIER=auto

# Data Provider (supabase | memory)
DATA_PROVIDER=supabase

# Initial Admin Account (optional one-time setup, remove after bootstrap)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=Platform Admin

# Initial Recruiter Account (optional one-time setup, remove after bootstrap)
INITIAL_RECRUITER_EMAIL=
INITIAL_RECRUITER_PASSWORD=
INITIAL_RECRUITER_NAME=Initial Recruiter

# Security
ALLOW_INSECURE_PASSWORD_RESET_TOKEN_RESPONSE=false

# File Upload
MAX_RESUME_FILE_SIZE_MB=4
ALLOWED_FILE_TYPES=application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
GENERAL_RATE_LIMIT_WINDOW_MS=900000
GENERAL_RATE_LIMIT_MAX_REQUESTS=400
SLOW_ENDPOINT_THRESHOLD_MS=1200
METRIC_SAMPLE_LIMIT=240
AI_REQUEST_TIMEOUT_MS=12000
AI_MATCH_TIMEOUT_MS=8000
AI_HEALTH_TIMEOUT_MS=3500
SHUTDOWN_TIMEOUT_MS=10000
